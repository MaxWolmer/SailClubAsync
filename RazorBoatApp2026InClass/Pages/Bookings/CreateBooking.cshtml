@page
@model RazorBoatApp2026InClass.Pages.Bookings.CreateBookingModel
@{
    ViewData["Title"] = "Create booking";
}

<h1>Create booking</h1>

<p>
    The ID: @Model.NewBoat.Id <br />
    The SailNumber: @Model.NewBoat.SailNumber <br />
    The Type of Boat: @Model.NewBoat.TheBoatType <br />
    The year of Construction: @Model.NewBoat.YearOfConstruction <br />
</p>

<form method="post">

    <div class="form-group">
        <label asp-for="@Model.NewId" class="control-label"></label>
        <input asp-for="@Model.NewId" class="form-control" />
    </div>

    <div class="form-group">
        <label asp-for="@Model.NewPhone" class="control-label"></label>
        <input asp-for="@Model.NewPhone" class="form-control" />
    </div>

    <div class="form-group">
        <label asp-for="@Model.NewStartDate" class="control-label"></label>
        <input asp-for="@Model.NewStartDate" class="form-control" />
    </div>

    <div class="form-group">
        <label asp-for="@Model.NewEndDate" class="control-label"></label>
        <input asp-for="@Model.NewEndDate" class="form-control" />
    </div>

    <div class="form-group">
        <label asp-for="@Model.NewDestination" class="control-label"></label>
        <input asp-for="@Model.NewDestination" class="form-control" />
    </div>

    <div class="form-group mt-3">
        <input type="submit" value="Opret booking" class="btn btn-primary" />
    </div>

    <div class="mt-2">
        <a asp-page="Index">Tilbage til oversigt</a>
    </div>

</form>